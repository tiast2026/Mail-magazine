  <a target=\"_blank\" href=\"{{PRODUCT1_URL}}\">\\n        <img width=\"100%\" src=\"{{COLOR2_IMAGE}}\" border=\"0\" alt=\"{{COLOR2_NAME}}\">\\n      </a><br>\\n      <font color=\"{{COLOR_SUBTEXT}}\" size=\"2\">{{COLOR2_NAME}}</font>\\n    </td>\\n  </tr>\\n</table>\n\n<!-- ■ 価格表示 -->\n<table width=\"100%\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\">\n  <tr>\n    <td align=\"center\" style=\"padding: 5px 0;\">\n      <font color=\"{{COLOR_MUTED}}\" size=\"2\"><strike>{{PRODUCT1_REGULAR_PRICE}}</strike></font><br>\n      <font color=\"{{COLOR_ACCENT}}\" size=\"5\"><b>{{PRODUCT1_SALE_PRICE}}</b></font>\n      <font color=\"{{COLOR_ACCENT}}\" size=\"2\">（{{PRODUCT1_DISCOUNT}}）</font>\n    </td>\n  </tr>\n</table>\n\n<!-- ■ CTAボタン -->\n<table width=\"100%\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\">\n  <tr>\n    <td align=\"center\" style=\"padding: 20px 0;\">\n      <table border=\"0\" cellpadding=\"0\" cellspacing=\"0\" width=\"80%\">\n        <tr>\n          <td align=\"center\" bgcolor=\"{{COLOR_PRIMARY}}\" style=\"padding: 16px 0; border-radius: 4px;\">\n            <a target=\"_blank\" href=\"{{PRODUCT1_URL}}\" style=\"color: #ffffff; text-decoration: none; display: block;\">\n              <font color=\"#ffffff\" size=\"3\"><b>{{CTA1_TEXT}}</b></font>\n            </a>\n          </td>\n        </tr>\n      </table>\n    </td>\n  </tr>\n</table>\n\n<!-- ■ 区切り線 -->\n<table width=\"90%\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\" align=\"center\">\n  <tr>\n    <td style=\"border-top: 1px solid {{COLOR_BORDER}}; padding: 15px 0 0 0;\"></td>\n  </tr>\n</table>\n\n<!-- ■ サブ商品（2商品目・コンパクト） -->\n<table width=\"100%\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\">\n  <tr>\n    <td align=\"center\" style=\"padding: 15px 0 5px 0;\">\n      <font color=\"{{COLOR_SUBTEXT}}\" size=\"2\">＊ こちらも同時に予約開始 ＊</font>\n    </td>\n  </tr>\n</table>\n\n<table width=\"100%\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\">\n  <tr>\n    <td align=\"center\" style=\