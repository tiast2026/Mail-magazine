    "html": "<!-- ============================== -->\n<!-- NOAHL メルマガテンプレートC -->\n<!-- ランキング型（マラソンラスト） -->\n<!-- ============================== -->\n\n<!-- ■ ヘッダー -->\n<table width=\"100%\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\" bgcolor=\"#ffffff\">\n  <tr>\n    <td align=\"center\" style=\"padding: 25px 0 20px 0;\">\n      <font color=\"{{COLOR_PRIMARY}}\" size=\"3\" style=\"letter-spacing: 4px;\">{{BRAND_LOGO}}</font><br>\n      <font color=\"{{COLOR_MUTED}}\" size=\"1\" style=\"letter-spacing: 2px;\">{{BRAND_TAGLINE}}</font>\n    </td>\n  </tr>\n</table>\n\n<!-- ■ セールバナー -->\n<table width=\"100%\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\">\n  <tr>\n    <td align=\"center\">\n      <a target=\"_blank\" href=\"{{URL_SALE}}\">\n        <img width=\"100%\" src=\"{{BANNER_IMAGE}}\" border=\"0\" alt=\"{{BANNER_ALT}}\">\n      </a>\n    </td>\n  </tr>\n</table>\n\n<!-- ■ 緊急性メッセージ -->\n<table width=\"100%\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\" bgcolor=\"{{COLOR_PANEL}}\">\n  <tr>\n    <td align=\"center\" style=\"padding: 25px 15px;\">\n      <font color=\"{{COLOR_ACCENT}}\" size=\"2\"><b>{{URGENCY_LABEL}}</b></font><br><br>\n      <font color=\"{{COLOR_TEXT}}\" size=\"4\"><b>みんなが買った<br>人気ランキングTOP3</b></font><br><br>\n      <font color=\"{{COLOR_SUBTEXT}}\" size=\"2\">{{SUBLINE}}</font>\n    </td>\n  </tr>\n</table>\n\n<!-- ■ NO.1 -->\n<table width=\"100%\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\">\n  <tr>\n    <td align=\"center\" style=\"padding: 25px 0 5px 0;\">\n      <font color=\"{{COLOR_ACCENT}}\" size=\"6\"><b>NO.1</b></font>\n    </td>\n  </tr>\n  <tr>\n    <td align=\"center\" style=\"padding: 5px 0;\">\n      <a target=\"_blank\" href=\"{{PRODUCT1_URL}}\">\n        <img src=\"{{PRODUCT1_IMAGE}}\" width=\"85%\" border=\"0\" alt=\"1位 {{PRODUCT1_NAME}}\">\n      </a>\n    </td>\n  </tr>\n  <tr>\n    <td align=\"center\" style=\"padding: 10px 0;\">\n      <font color=\"{{COLOR_TEXT}}\" size=\"3\"><b>{{PRODUCT1_NAME}}</b></font><br>\n      <font color=\"{{COLOR_SUBTEXT}}\" size=\"2\">一番人気のカラー：<b>{{PRODUCT1_COLOR}}</b></font><br><br>\n      <font color=\"{{COLOR_MUTED}}\" size=\"2\"><strike>{{PRODUCT1_REGULAR_PRICE}}</strike></font>\n      <font color=\"{{COLOR_ACCENT}}\" size=\"3\"><b> {{PRODUCT1_SALE_PRICE}}</b></font>\n    </td>\n  </tr>\n  <tr>\n    <td align=\"center\" style=\"padding: 15px 0 25px 0;\">\n      <table border=\"0\" cellpadding=\"0\" cellspacing=\"0\" width=\"80%\">\n        <tr>\n          <td align=\"center\" bgcolor=\"{{COLOR_PRIMARY}}\" style=\"padding: 16px 0; border-radius: 4px;\">\n            <a target=\"_blank\" href=\"{{PRODUCT1_URL}}\" style=\"color: #ffffff; text-decoration: none; display: block;\">\n              <font color=\"#ffffff\" size=\"3\"><b>1位のアイテムを見る →</b></font>\n            </a>\n          </td>\n        </tr>\n      </table>\n    </td>\n  </tr>\n</table>\n\n<!-- ■ 区切り線 -->\n<table width=\"90%\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\" align=\"center\">\n  <tr>\n    <td style=\"border-top: 1px solid {{COLOR_BORDER}};\"></td>\n  </tr>\n</table>\n\n<!-- ■ NO.2 -->\n<table width=\"100%\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\">\n  <tr>\n    <td align=\"center\" style=\"padding: 25px 0 5px 0;\">\n      <font color=\"{{COLOR_PRIMARY}}\" size=\"5\"><b>NO.2</b></font>\n    </td>\n  </tr>\n  <tr>\n    <td align=\"center\" style=\"padding: 5px 0;\">\n      <a target=\"_blank\" href=\"{{PRODUCT2_URL}}\">\n        <img src=\"{{PRODUCT2_IMAGE}}\" width=\"75%\" border=\"0\" alt=\"2位 {{PRODUCT2_NAME}}\">\n      </a>\n    </td>\n  </tr>\n  <tr>\n    <td align=\"center\" style=\"padding: 10px 0;\">\n      <font color=\"{{COLOR_TEXT}}\" size=\"3\"><b>{{PRODUCT2_NAME}}</b></font><br>\n      <font color=\"{{COLOR_SUBTEXT}}\" size=\"2\">一番人気のカラー：<b>{{PRODUCT2_COLOR}}</b></font><br><br>\n      <font color=\"{{COLOR_MUTED}}\" size=\"2\"><strike>{{PRODUCT2_REGULAR_PRICE}}</strike></font>\n      <font color=\"{{COLOR_ACCENT}}\" size=\"3\"><b> {{PRODUCT2_SALE_PRICE}}</b></font>\n    </td>\n  </tr>\n  <tr>\n    <td align=\"center\" style=\"padding: 15px 0 25px 0;\">\n      <table border=\"0\" cellpadding=\"0\" cellspacing=\"0\" width=\"80%\">\n        <tr>\n          <td align=\"center\" bgcolor=\"{{COLOR_PRIMARY}}\" style=\"padding: 14px 0; border-radius: 4px;\">\n            <a target=\"_blank\" href=\"{{PRODUCT2_URL}}\" style=\"color: #ffffff; text-decoration: none; display: block;\">\n              <font color=\"#ffffff\" size=\"2\"><b>2位のアイテムを見る →</b></font>\n            </a>\n          </td>\n        </tr>\n      </table>\n    </td>\n  </tr>\n</table>\n\n<!-- ■ 区切り線 -->\n<table width=\"90%\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\" align=\"center\">\n  <tr>\n    <td style=\"border-top: 1px solid {{COLOR_BORDER}};\"></td>\n  </tr>\n</table>\n\n<!-- ■ NO.3 -->\n<table width=\"100%\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\">\n  <tr>\n    <td align=\"center\" style=\"padding: 25px 0 5px 0;\">\n      <font color=\"{{COLOR_PRIMARY}}\" size=\"5\"><b>NO.3</b></font>\n    </td>\n  </tr>\n  <tr>\n    <td align=\"center\" style=\"padding: 5px 0;\">\n      <a target=\"_blank\" href=\"{{PRODUCT3_URL}}\">\n        <img src=\"{{PRODUCT3_IMAGE}}\" width=\"75%\" border=\"0\" alt=\"3位 {{PRODUCT3_NAME}}\">\n      </a>\n    </td>\n  </tr>\n  <tr>\n    <td align=\"center\" style=\"padding: 10px 0;\">\n      <font color=\"{{COLOR_TEXT}}\" size=\"3\"><b>{{PRODUCT3_NAME}}</b></font><br>\n      <font color=\"{{COLOR_SUBTEXT}}\" size=\"2\">一番人気のカラー：<b>{{PRODUCT3_COLOR}}</b></font><br><br>\n      <font color=\"{{COLOR_MUTED}}\" size=\"2\"><strike>{{PRODUCT3_REGULAR_PRICE}}</strike></font>\n      <font color=\"{{COLOR_ACCENT}}\" size=\"3\"><b> {{PRODUCT3_SALE_PRICE}}</b></font>\n    </td>\n  </tr>\n  <tr>\n    <td align=\"center\" style=\"padding: 15px 0 25px 0;\">\n      <table border=\"0\" cellpadding=\"0\" cellspacing=\"0\" width=\"80%\">\n        <tr>\n          <td align=\"center\" bgcolor=\"{{COLOR_PRIMARY}}\" style=\"padding: 14px 0; border-radius: 4px;\">\n            <a target=\"_blank\" href=\"{{PRODUCT3_URL}}\" style=\"color: #ffffff; text-decoration: none; display: block;\">\n              <font color=\"#ffffff\" size=\"2\"><b>3位のアイテムを見る →</b></font>\n            </a>\n          </td>\n        </tr>\n      </table>\n    </td>\n  </tr>\n</table>\n\n<!-- ■ もっと見るリンク -->\n<table width=\"100%\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\">\n  <tr>\n    <td align=\"center\" style=\"padding: 15px 0 25px 0;\">\n      <a target=\"_blank\" href=\"{{URL_SALE}}\">\n        <font color=\"{{COLOR_PRIMARY}}\" size=\"2\"><b>≫ セール対象アイテムをもっと見る</b></font>\n      </a>\n    </td>\n  </tr>\n</table>\n\n<!-- ■ クーポンセクション -->\n<table width=\"90%\" border=\"0\" cellpadding=\"20\" cellspacing=\"0\" align=\"center\" bgcolor=\"{{COLOR_PANEL}}\">\n  <tr>\n    <td align=\"center\">\n      <font color=\"{{COLOR_SUBTEXT}}\" size=\"2\">＼ 読者様限定 ／</font><br><br>\n      <font color=\"{{COLOR_TEXT}}\" size=\"3\"><b>終了前に使える特別クーポン</b></font><br><br>\n      <table border=\"0\" cellpadding=\"0\" cellspacing=\"0\" width=\"85%\">\n        <tr>\n          <td align=\"center\" bgcolor=\"{{COLOR_ACCENT}}\" style=\"padding: 16px 0; border-radius: 4px;\">\n            <a target=\"_blank\" href=\"{{COUPON_URL}}\" style=\"color: #ffffff; text-decoration: none; display: block;\">\n              <font color=\"#ffffff\" size=\"3\"><b>クーポンを取得する →</b></font>\n            </a>\n          </td>\n        </tr>\n      </table>\n    </td>\n  </tr>\n</table>\n\n<!-- ■ フッター -->\n<table width=\"100%\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\" bgcolor=\"{{COLOR_PANEL}}\">\n  <tr>\n    <td align=\"center\" style=\"padding: 25px 15px;\">\n      <font color=\"{{COLOR_PRIMARY}}\" size=\"2\"><b>▽ NOAHLの新作をチェック ▽</b></font><br><br>\n      <a target=\"_blank\" href=\"{{URL_NEW_ARRIVALS}}\">\n        <font color=\"{{COLOR_TEXT}}\" size=\"2\">新作一覧を見る →</font>\n      </a><br><br>\n      <font color=\"{{COLOR_MUTED}}\" size=\"1\">──────────────</font><br><br>\n      <a target=\"_blank\" href=\"{{URL_REVIEW}}\">\n        <font color=\"{{COLOR_SUBTEXT}}\" size=\"1\">レビュー投稿でプレゼント♪ 詳しくはこちら →</font>\n      </a>\n    </td>\n  </tr>\n</table>\n\n<table width=\"100%\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\">\n  <tr>\n    <td align=\"center\" style=\"padding: 20px 0;\">\n      <font color=\"{{COLOR_MUTED}}\" size=\"1\" style=\"letter-spacing: 2px;\">{{BRAND_LOGO}} ( ノアル )</font>\n    </td>\n  </tr>\n</table>",
